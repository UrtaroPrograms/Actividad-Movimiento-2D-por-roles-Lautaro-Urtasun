[sub_resource type="GDScript" id="GDScript_4e5bt"]
script/source = "extends CharacterBody2D


const SPEED = 150
const JUMP_VELOCITY = -300.0
const DASH_SPEED = 900

var heading = 1  #Inicializamos la variable 'heading' para indicar la dirección a la quedó apuntando el personaje. Solo la usa el dash para deteminar su dirección si se encuentra quieto.
var double_jump_used = false
var dash_used = false
var is_dashing = false

func _physics_process(delta: float) -> void:
	# Primero se añade la gravedad.
	if !is_dashing: #Solo ejecutamos el código de físicas si NO estamos dasheando.
	
		if not is_on_floor():
			velocity += get_gravity() * delta

	# Manejamos el salto:.
		if Input.is_action_just_pressed(\"jump\") and is_on_floor(): #Primero comprobamos si estamos en el suelo y realizamos el salto correspondiente de ser así.
			velocity.y = JUMP_VELOCITY
			double_jump_used = false #Declaramos el doble salto como disponible al momento de realizar el primer salto para ahorrarnos chequeo
	
		if Input.is_action_just_pressed(\"jump\") and !is_on_floor(): #Si apretamos el salto y NO estamos en el suelo, comprobamos si está disponible el doble salto y si lo está, lo ejecutamos
			if double_jump_used == false:
				double_jump_used = true
				velocity.y = JUMP_VELOCITY
			
		if Input.is_action_just_pressed(\"dash\") and !dash_used: #Si apretamos el botón de dash, entonces chequeamos si está disponible, si lo está, lo ejecutamos y cambiamos a verdaderas las variables de dasheo.
			dash_used = true;
			is_dashing = true;
			velocity.y = 0;  #El personaje no está afectado por la gravedad mientras realiza su dash
			$DashDuration.start() #Activamos el timer del dash
		
	
		#Movemos al personaje según los inputs del jugador.
		
		var direction := Input.get_axis(\"move_left\", \"move_right\")
		if direction:
			velocity.x = direction * SPEED
		else:
			velocity.x = move_toward(velocity.x, 0, SPEED)
		
	else:
		velocity.x = DASH_SPEED * heading  #Cambiamos la velocidad por la velocidad del dash. Como las físicas se suspenden al activar el dash, este no se verá afectado por la gravedad ni la inercia durante el dash (pero sí después)

	move_and_slide()
	
	# Al final calculamos si el personaje debería mirar para la izquierda o la derecha según su velocidad x. Utilizamos un else if para que no quede mirando a la derecha por defecto. 
	if velocity.x < 0:  
		$AnimatedSprite2D.flip_h = true
		heading = -1
	else: if velocity.x > 0:
		$AnimatedSprite2D.flip_h = false
		heading = 1
	
func _call_animation(animation: String):	#Llamamos al AnimatedSprite2D para que reproduzca una de las animaciones del personaje.
	$AnimatedSprite2D.play(animation)
	


func _on_dash_duration_timeout():   #Cuando termina el dash, activamos el timer de cooldown y de recuperación, al mismo tiempo que desactivamos el estado de dash
	is_dashing = false
	$DashCooldown.start()
	$DashRecovery.start()
	
func _on_dash_cooldown_timeout(): #Al concluir el cooldown el dash vuelve a estar  disponible
	dash_used = false




func _on_hitbox_body_entered(body: Node2D):	#Cuando un objeto ingresa al hitbox (un Area2D), chequeamos si no es el jugador y si es un CharacterBody2D, entonces printeamos golpeado.
	if body != self:
		if body is CharacterBody2D:
			print (\"Golpeado\")
"

